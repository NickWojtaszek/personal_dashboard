# Gemini AI (optional - for AI assistant features)
GEMINI_API_KEY=

# Google OAuth (optional - for Google Sheets invoice export)
# 1. Create project at https://console.cloud.google.com
# 2. Enable Google Sheets API and Google Drive API
# 3. Create OAuth 2.0 Client ID (Web application)
# 4. Add http://localhost:3000 to Authorized JavaScript origins
GOOGLE_CLIENT_ID=

# Supabase (optional - for cloud persistence + auth; falls back to localStorage with no auth)
# When configured, Google OAuth login is required and only allowed_users can access the app.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

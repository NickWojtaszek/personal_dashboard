# Whisper model: tiny | base | small | medium | large-v3
# tiny/base run on CPU; medium/large benefit from GPU
WHISPER_MODEL=base

# Device: cpu | cuda | auto (auto picks GPU if available)
WHISPER_DEVICE=cpu

# Compute precision: int8 (CPU), float16 (GPU), int8_float16 (mixed)
WHISPER_COMPUTE_TYPE=int8

# Beam search width — higher = more accurate, slower
WHISPER_BEAM_SIZE=5

# Comma-separated CORS origins.
# Add your production frontend URL here when deploying.
# Example: http://localhost:5173,http://localhost:3000,https://personaldashboard-production-a145.up.railway.app
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Reject uploads larger than this (in MB)
MAX_AUDIO_SIZE_MB=25

# Default language if client doesn't specify
DEFAULT_LANGUAGE=en
